{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": [
            "ES2022"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        /* Ensure types for VS Code are recognized */
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        /* esbuild doesn't do type checking, so this helps VS Code keep up */
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}